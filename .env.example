# Database driver
YII_DB_DRIVER=mysql

# Yii environment: dev | prod | test (web/index.php also maps APP_ENV)
YII_ENV=dev

# Use this when app is outside internal Docker network (e.g. managed DB URL)
# Example value format: mysql://user:pass@host:port/dbname
MYSQL_PUBLIC_URL=

# Dev + MYSQL_* URL: set to 1 only if you intentionally want the app DB on a remote URL
# while developing locally. Project "CREATE DATABASE" then runs on that remote host,
# so it will NOT appear in local phpMyAdmin. Leave unset/0 to use local MySQL in dev.
YII_DB_USE_URL_IN_DEV=

# Boss / local-primary workflow: keep the MAIN app DB on localhost even if MYSQL_PUBLIC_URL
# is set. Primary = YII_DB_* below; remote URL is used only as optional backup.
# Uncomment on the machine where phpMyAdmin points to 127.0.0.1 (local primary + URL backup).
# YII_DB_FORCE_LOCAL_PRIMARY=1
YII_DB_FORCE_LOCAL_PRIMARY=

# Optional explicit backup URL (overrides auto-pick from MYSQL_PUBLIC_URL when primary is local).
# Same format as MYSQL_PUBLIC_URL. Used only if backup host differs from primary host.
YII_DB_BACKUP_URL=

# Mirror new project databases to backup: 1 (default) or 0 to disable CREATE on backup only.
YII_DB_BACKUP_SYNC=

# Backup sync mode:
# 0/empty = best effort (master tetap jalan jika backup gagal)
# 1 = strict (request gagal jika sinkronisasi ke backup gagal)
YII_DB_BACKUP_SYNC_STRICT=

# Optional failover:
# set 1 to switch app connection to backup automatically when primary is unreachable.
YII_DB_FAILOVER_TO_BACKUP=

# MySQL configuration (used when YII_DB_DRIVER=mysql)
# Coolify internal Docker network host:
YII_DB_HOST=mysql-database-xb782ufttxvm1k992vvkup98
YII_DB_PORT=3306
YII_DB_NAME=default
YII_DB_USER=mysql
YII_DB_PASSWORD=

# Public app URL for generated links (Coolify domain)
# Example: https://your-app.example.com
APP_URL=

